!! Noun inflection
!  ---------------
!! The Gunwinggu language nouns inflect in number and cases.

LEXICON NounGenderPreBase
0:na^ INounBase ;
0:ngal^ IINounBase ;
0:man^ IIINounBase ;
0:kun^ IVNounBase ;
0:0^ VNounBase ;
0:0^ NominalDeverbals ;
0:0^ PlaceNouns ;

LEXICON AllNounClasses
INounBase ;
IINounBase ;
IIINounBase ;
IVNounBase ;
VNounBase ;




! =======


LEXICON PostNominal
@R.TYPE.V@ BPINPreBase ;
@R.TYPE.N@ # ;



! vim: set ft=xfst-lexc:

