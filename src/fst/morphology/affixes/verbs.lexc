@R.TENSE.NP@+NonPst:@R.TENSE.NP@n^ # ;
@R.TENSE.P@+PstPerf:@R.TENSE.P@ng^ # ;
@R.TENSE.P@+PstImperf:@R.TENSE.P@ni^ # ;
