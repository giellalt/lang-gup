@R.TENSE.NP@+NonPst:@R.TENSE.NP@ng^ # ;
@R.TENSE.P@+PstPerf:@R.TENSE.P@~i^ # ;
@R.TENSE.P@+PstImperf:@R.TENSE.P@ngi^ # ;
