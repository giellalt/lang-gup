!! Verb inflection
!  ---------------
!! The Gunwinggu language verbs inflect in persons.

LEXICON TSOPreBase 
!!   Singular - Intransitives !!
@P.VALENCE.INTR@@P.TENSE.P@ SingleIntransPastTSO ;
@P.VALENCE.INTR@@P.TENSE.NP@ SingleIntransNonPastTSO ;
!!  Dual - Intransitives !!
@P.VALENCE.INTR@@P.TENSE.P@ DualIntransPastTSO ;
@P.VALENCE.INTR@@P.TENSE.NP@ DualIntransNonPastTSO ;
!!  Trial - Intransitives !!
@P.VALENCE.INTR@@P.TENSE.P@ TrialIntransPastTSO ;
@P.VALENCE.INTR@@P.TENSE.NP@ TrialIntransNonPastTSO ;
!!  Plural - Intransitives !!
@P.VALENCE.INTR@@P.TENSE.P@ PluralIntransPastTSO ;
@P.VALENCE.INTR@@P.TENSE.NP@ PluralIntransNonPastTSO ; 

!!  Transitives - 3 Single obj !!
@P.VALENCE.TRNS@@P.TENSE.P@ TransPast3pObjTSO ; 
@P.VALENCE.TRNS@@P.TENSE.NP@ TransNonPast3pObjTSO ; 
!! Transitives - 3 Dual Obj !!
@P.VALENCE.TRNS@@P.TENSE.P@ TransPast3pDualObjTSO ; 
@P.VALENCE.TRNS@@P.TENSE.NP@ TransNonPast3pDualObjTSO ; 
!! Transitives - 3 Plural Obj !!
@P.VALENCE.TRNS@@P.TENSE.P@ TransPast3PlObjTSO ; 
@P.VALENCE.TRNS@@P.TENSE.NP@ TransNonPast3PlObjTSO ; 
!! Transitives - 2 Person Obj !!
@P.VALENCE.TRNS@@P.TENSE.P@ TransPast2Obj ; 
@P.VALENCE.TRNS@@P.TENSE.NP@ TransNonPast2Obj ; 
!! Transitives - 1 person obj !!
@P.VALENCE.TRNS@@P.TENSE.P@ TransPast1Obj ; 
@P.VALENCE.TRNS@@P.TENSE.NP@ TransNonPast1Obj ; 

LEXICON SingleIntransPastTSO
+V+1Sg+Past:nga^ DirPreBase ;
+V+2Sg+Past:yi^ DirPreBase ;
+V+3Sg+Past:0^ DirPreBase ;
+V+3Sg+Past:bi^ DirPreBase ;

LEXICON SingleIntransNonPastTSO
+V+1Sg.+NonPast:nga^ DirPreBase ;
+V+2Sg.+NonPast:yi^ DirPreBase ;
+V+3Sg.+NonPast:ka^ DirPreBase ;

LEXICON DualIntransPastTSO
+V+12m+Past:ngar(r)^ DirPreBase ;
+V+1ua.excl+Past:ngane^ DirPreBase ;
+V+2ua+Past:ngune^ DirPreBase ;
+V+3ua+Past:bene^ DirPreBase ;

LEXICON DualIntransNonPastTSO
+V+12m.+NonPast:ngar(r)^ DirPreBase ;
+V+1ua.excl.+NonPast:ngane^ DirPreBase ;
+V+2ua.+NonPast:ngune^ DirPreBase ;
+V+3ua.+NonPast:kabene^ DirPreBase ;

LEXICON TrialIntransPastTSO
+V+12ua+Past:kane^ DirPreBase ;

LEXICON TrialIntransNonPastTSO
+V+12ua.+NonPast:kane^ DirPreBase ;

LEXICON PluralIntransPastTSO
+V+1Pl.excl+Past:ngarri^ DirPreBase ;
+V+1Pl.incl+Past:karri^ DirPreBase ;
+V+2Pl+Past:ngurri^ DirPreBase ;
+V+3Pl+Past:birri^ DirPreBase ;

LEXICON PluralIntransNonPastTSO
+V+1Pl.excl.+NonPast:ngarri^ DirPreBase ;
+V+1Pl.incl.+NonPast:karri^ DirPreBase ;
+V+2Pl.+NonPast:ngurri^ DirPreBase ;
+V+3Pl.+NonPast:kabirri^ DirPreBase ;

LEXICON TransPast3pObjTSO
+V+1Sg.3sg+Past:nga^ DirPreBase ;
+V+2Sg.3sg+Past:yi^ DirPreBase ;
+V+3Sg.3sg+Past:0^ DirPreBase ;
+V+3Sg.3Hsg+Past:bi^ DirPreBase ;
+V+12m.3sg+Past:ngarr^ DirPreBase ;
+V+2ua.3sg+Past:ngune^ DirPreBase ;
+V+1ua.excl.3sg+Past:ngane^ DirPreBase ;
+V+3ua.3sg+Past:bene^ DirPreBase ;
+V+12ua.3sg+Past:kane^ DirPreBase ;
+V+1Pl.excl.3sg+Past:ngarri^ DirPreBase ;
+V+1Pl.incl.3sg+Past:karri^ DirPreBase ;
+V+2Pl.3sg+Past:ngurri^ DirPreBase ;
+V+3Pl.3sg+Past:birri^ DirPreBase ;

LEXICON TransNonPast3pObjTSO
+V+1Sg.3sg.+NonPast:nga^ DirPreBase ;
+V+2Sg.3sg.+NonPast:yi^ DirPreBase ;
+V+3Sg.3sg.+NonPast:ka^ DirPreBase ;
+V+3Sg.3Hsg.+NonPast:kabi^ DirPreBase ;
+V+12m.3sg.+NonPast:ngarr^ DirPreBase ;
+V+1ua.excl.3sg.+NonPast:ngane^ DirPreBase ;
+V+2ua.3sg.+NonPast:ngune^ DirPreBase ;
+V+3ua.3sg.+NonPast:kabene^ DirPreBase ;
+V+12ua.3sg.+NonPast:kane^ DirPreBase ;
+V+1Pl.excl.3sg.+NonPast:ngarri^ DirPreBase ;
+V+1Pl.incl.3sg.+NonPast:karri^ DirPreBase ;
+V+2Pl.3sg.+NonPast:ngurri^ DirPreBase ;
+V+3Pl.3sg.+NonPast:kabirri^ DirPreBase ;

LEXICON TransPast3pDualObjTSO
+V+1Sg.3ua+Past:ngabenbene^ DirPreBase ;
+V+2Sg.3ua+Past:yibenbene^ DirPreBase ;
+V+3Sg.3ua+Past:benbene^ DirPreBase ;
+V+3Sg.3ua+Past:benmene^ DirPreBase ;
+V+12m.3ua+Past:ngarrbenbene^ DirPreBase ;
+V+3ua.3ua+Past:bindi^ DirPreBase ;
+V+2ua.3ua+Past:ngunebenbene^ DirPreBase ;
+V+2ua.3ua+Past:ngurrbenbene^ DirPreBase ;
+V+1ua.excl.3ua+Past:nganebenbene^ DirPreBase ;
+V+1ua.excl.3ua+Past:ngarrbenbene^ DirPreBase ;
+V+12ua.3ua+Past:kanebenbene^ DirPreBase ;
+V+12ua.3ua+Past:karrbenbene^ DirPreBase ;
+V+1Pl.excl.3ua+Past:ngarribenbene^ DirPreBase ;
+V+1Pl.excl.3ua+Past:ngarrbenbene^ DirPreBase ;
+V+1Pl.incl.3ua+Past:karribenbene^ DirPreBase ;
+V+1Pl.incl.3ua+Past:karrbenbene^ DirPreBase ;
+V+2Pl.3ua+Past:ngurribenbene^ DirPreBase ;
+V+2Pl.3ua+Past:ngurrbenbene^ DirPreBase ;
+V+3Pl.3ua+Past:bindi^ DirPreBase ;

LEXICON TransNonPast3pDualObjTSO
+V+1Sg.3ua.+NonPast:ngabenbene^ DirPreBase ;
+V+2Sg.3ua.+NonPast:yibenbene^ DirPreBase ;
+V+3Sg.3ua.+NonPast:kabenbene^ DirPreBase ;
+V+12m.3ua.+NonPast:ngarrbenbene^ DirPreBase ;
+V+3ua.3ua.+NonPast:kabindi^ DirPreBase ;
+V+2ua.3ua.+NonPast:ngunebenbene^ DirPreBase ;
+V+2ua.3ua.+NonPast:ngurrbenbene^ DirPreBase ;
+V+1ua.excl.3ua.+NonPast:nganebenbene^ DirPreBase ;
+V+1ua.excl.3ua.+NonPast:ngarrbenbene^ DirPreBase ;
+V+12ua.3ua.+NonPast:kanebenbene^ DirPreBase ;
+V+12ua.3ua.+NonPast:karrbenbene^ DirPreBase ;
+V+1Pl.excl.3ua.+NonPast:ngarribenbene^ DirPreBase ;
+V+1Pl.excl.3ua.+NonPast:ngarrbenbene^ DirPreBase ;
+V+1Pl.incl.3ua.+NonPast:karribenbene^ DirPreBase ;
+V+1Pl.incl.3ua.+NonPast:karrbenbene^ DirPreBase ;
+V+2Pl.3ua.+NonPast:ngurribenbene^ DirPreBase ;
+V+2Pl.3ua.+NonPast:ngurrbenbene^ DirPreBase ;
+V+3Pl.3ua.+NonPast:kabindi^ DirPreBase ;

LEXICON TransPast3PlObjTSO
+V+1Sg.3pl+Past:ngaben^ DirPreBase ;
+V+2Sg.3pl+Past:yiben^ DirPreBase ;
+V+3Sg.3pl+Past:ben^ DirPreBase ;
+V+12m.3pl+Past:ngarrben^ DirPreBase ;
+V+3ua.3pl+Past:bindi^ DirPreBase ;
+V+2ua.3pl+Past:nguneben^ DirPreBase ;
+V+2ua.3pl+Past:ngurrben^ DirPreBase ;
+V+1ua.excl.3pl+Past:nganeben^ DirPreBase ;
+V+1ua.excl.3pl+Past:ngarrben^ DirPreBase ;
+V+12ua.3pl+Past:kaneben^ DirPreBase ;
+V+12ua.3pl+Past:karrben^ DirPreBase ;
+V+1Pl.excl.3pl+Past:ngarriben^ DirPreBase ;
+V+1Pl.excl.3pl+Past:ngarrben^ DirPreBase ;
+V+1Pl.incl.3pl+Past:karriben^ DirPreBase ;
+V+1Pl.incl.3pl+Past:karrben^ DirPreBase ;
+V+2Pl.3pl+Past:ngurriben^ DirPreBase ;
+V+2Pl.3pl+Past:ngurrben^ DirPreBase ;
+V+3Pl.3pl+Past:bindi^ DirPreBase ;

LEXICON TransNonPast3PlObjTSO
+V+1Sg.3pl.+NonPast:ngaben^ DirPreBase ;
+V+2Sg.3pl.+NonPast:yiben^ DirPreBase ;
+V+3Sg.3pl.+NonPast:kaben^ DirPreBase ;
+V+12m.3pl.+NonPast:ngarrben^ DirPreBase ;
