@R.TENSE.P@+PstPerf:@R.TENSE.P@~om^ # ;
@R.TENSE.P@+PstImperf:@R.TENSE.P@ni^ # ;

LEXICON V5aPostBase
+RR:rre^ RRConj ;
@R.TENSE.NP@+NonPst:@R.TENSE.NP@ng^ # ;
