+V+12ua.3pl.+NonPast:kaneben^ DirPreBase ;
+V+12ua.3pl.+NonPast:karrben^ DirPreBase ;
+V+1Pl.excl.3pl.+NonPast:ngarriben^ DirPreBase ;
+V+1Pl.excl.3pl.+NonPast:ngarrben^ DirPreBase ;
+V+1Pl.incl.3pl.+NonPast:karriben^ DirPreBase ;
+V+1Pl.incl.3pl.+NonPast:karrben^ DirPreBase ;
+V+2Pl.3pl.+NonPast:ngurriben^ DirPreBase ;
+V+2Pl.3pl.+NonPast:ngurrben^ DirPreBase ;
+V+3Pl.3pl.+NonPast:kabindi^ DirPreBase ;

LEXICON TransPast2Obj
+V+3Sg.2+Past:ngun^ DirPreBase ;
+V+1Sg.2ua+Past:benbene^ DirPreBase ;
+V+3Sg.2ua+Past:ngunbene^ DirPreBase ;
+V+1Sg.2+Past:0^ DirPreBase ;
+V+3Pl.2pl+Past:ngundi^ DirPreBase ;
+V+1Pl.2+Past:ngundi^ DirPreBase ;
+V+1Pl.2pl+Past:bi^ DirPreBase ;

LEXICON TransNonPast2Obj
+V+3Sg.2.+NonPast:ngun^ DirPreBase ;
+V+1Sg.2ua.+NonPast:benbene^ DirPreBase ;
+V+3Sg.2ua.+NonPast:ngunbene^ DirPreBase ;
+V+1Sg.2.+NonPast:0^ DirPreBase ;
+V+3Pl.2pl.+NonPast:ngundi^ DirPreBase ;
+V+1Pl.2.+NonPast:ngundi^ DirPreBase ;
+V+1Pl.2pl.+NonPast:bi^ DirPreBase ;

LEXICON TransPast1Obj
+V+2Sg.1+Past:kan^ DirPreBase ;
+V+3Sg.1pl+Past:kan^ DirPreBase ;
+V+3Sg.1+Past:ngan^ DirPreBase ;
+V+2Sg.1ua+Past:kanbene^ DirPreBase ;
+V+3Sg.1ua+Past:kanbene^ DirPreBase ;
