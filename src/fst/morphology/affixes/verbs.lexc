LEXICON V3dConj
@R.TENSE.NP@+NonPst:@R.TENSE.NP@n^ # ;
@R.TENSE.P@+PstPerf:@R.TENSE.P@~inj^ # ;
@R.TENSE.P@+PstImperf:@R.TENSE.P@ni^ # ;
+Imp:0^ # ;
+Irr:yinj^ # ; 
+Irr:yi^ # ; 

LEXICON V3IrrPostBase
+RR:rre^ RRConj ;
@R.TENSE.NP@+NonPst:@R.TENSE.NP@n^ # ;
@R.TENSE.P@+PstPerf:@R.TENSE.P@neng^ # ;
@R.TENSE.P@+PstImperf:@R.TENSE.P@ni^ # ;
